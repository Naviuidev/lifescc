# Hostinger: public_html/test/.htaccess

# React first — do not list index.php here (Hostinger prefers PHP otherwise)
DirectoryIndex index.html

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /test/

    # API only → PHP
    RewriteRule ^api(/.*)?$ index.php [L,QSA]

    # Existing files (assets, uploads, index.html, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Client-side routes → React
    RewriteRule ^ index.html [L]
</IfModule>

<Files ".env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>
