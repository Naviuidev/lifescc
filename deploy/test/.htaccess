# Hostinger: public_html/test/.htaccess
# React SPA at /test/ + API at /test/api/*

DirectoryIndex index.html

<IfModule mod_negotiation.c>
    Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /test/

    # API → PHP (only paths starting with api/)
    RewriteRule ^api(/.*)?$ index.php [L,QSA]

    # Real files/folders (assets, uploads, index.html, favicon, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # All other URLs → React (client-side routes)
    RewriteRule ^ index.html [L]
</IfModule>

# Block web access to secrets
<Files ".env">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</Files>
