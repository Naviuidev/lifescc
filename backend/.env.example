# Match the same MySQL server, database name, and user you use in phpMyAdmin.
# DB_NAME should be the database you created (e.g. lifescc).

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lifescc

# Common on local phpMyAdmin (XAMPP/MAMP/WAMP): root + no password
DB_USER=root
DB_PASS=

# If you created a dedicated MySQL user in phpMyAdmin (or use Docker Compose):
# DB_USER=lifescc
# DB_PASS=lifescc
