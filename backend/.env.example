# Match the same MySQL server, database name, and user you use in phpMyAdmin.
# DB_NAME should be the database you created (e.g. lifescc).
#
# If GET /api/health shows database: unavailable, MySQL is not reachable or the
# database/user is wrong. From repo root: mysql -u root -p < database/init.sql
# (or import that file in phpMyAdmin). Uncomment for connection error text on /api/health:
# API_DEBUG=1

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lifescc

# Common on local phpMyAdmin (XAMPP/MAMP/WAMP): root + no password
DB_USER=root
DB_PASS=

# If you created a dedicated MySQL user in phpMyAdmin (or use Docker Compose):
# DB_USER=lifescc
# DB_PASS=lifescc

# CORS (Vite dev server). On production same-origin deploy, this is unused.
CORS_ORIGIN=http://localhost:5173

# Subfolder deploy on shared hosting (e.g. https://tefenoza.com/test/)
# Production: APP_BASE_PATH=/test — see deploy/test/.env.hostinger
# Local dev: leave empty (backend/.env)
APP_BASE_PATH=

# Writable chatbot toggle file (auto-used from data/siteEmbeddedChatbot.json on server)
# SITE_CHATBOT_JSON=/home/.../public_html/test/data/siteEmbeddedChatbot.json

# Gmail SMTP (use an App Password, not your normal Gmail password)
MAIL_TO=naveenreddy.webdev@gmail.com
# Contact form inbox (falls back to MAIL_TO, then code default if unset)
CONTACT_MAIL_TO=naveenreddyhosur921@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=naveenreddy.webdev@gmail.com
SMTP_PASS=
SMTP_FROM_EMAIL=naveenreddy.webdev@gmail.com
SMTP_FROM_NAME=Lifescc Bookings
